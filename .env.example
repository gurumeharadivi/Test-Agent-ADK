# ─── Jira Integration ─────────────────────────────────────────────────────────
JIRA_URL=https://your-org.atlassian.net/
JIRA_USERNAME=your-email@example.com
JIRA_API_TOKEN=your-jira-api-token

# ─── Google AI Backend (choose ONE of the two options below) ──────────────────

# Option A: Google AI Studio (simplest — no cloud account needed)
# Leave the VERTEX variables below commented out and set only this:
# GOOGLE_API_KEY=your-google-ai-studio-api-key

# Option B: Google Cloud Vertex AI
# 1. Create a GCP project with billing enabled
# 2. Run: gcloud auth application-default login
# 3. Run: gcloud config set project YOUR-PROJECT-ID
# Then fill in the values below:
GOOGLE_GENAI_USE_VERTEXAI=1
GOOGLE_CLOUD_PROJECT=your-gcp-project-id
GOOGLE_CLOUD_LOCATION=us-central1
CLOUDSDK_CORE_PROJECT=your-gcp-project-id
GOOGLE_APPLICATION_CREDENTIALS=/path/to/application_default_credentials.json
